# Database — Railway will provide this automatically when you add a PostgreSQL service
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT Secret — make this a long random string (e.g. 64 random characters)
JWT_SECRET="replace-this-with-a-long-random-secret"

# Port — Railway sets this automatically, but 3001 is the local default
PORT=3001

# OpenAI — required for insurance card AI parsing (GPT-4o Vision)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
