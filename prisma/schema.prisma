// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum DataSource {
  Forager
  ForagerAPI
  ForagerCSVUpload
  Manual
}

enum VisitStatus {
  Upcoming
  Completed
  Cancelled
  NoShow
}

enum ClaimStatus {
  Pending
  Submitted
  Pended
  Paid
  Denied
  ShortPaid
  Overpaid
}

enum EligibilityStatus {
  passed
  failed
  unchecked
}

enum PaymentType {
  Coinsurance
  Copay
  Deductible
}

enum PayorType {
  Insurance
  Patient
}

enum PaymentMethod {
  Cash
  CreditCard
  Check
  Electronic
}

enum VisitLocation {
  InClinic
  Telehealth
}

enum VisitType {
  FollowUp
  NewPatient
}

enum PolicyType {
  Primary
  Secondary
}

enum UserRole {
  Admin
  Biller
  Provider
  FrontDesk
}

enum ProviderLicenseType {
  MD
  DO
  NP
  PA_C
  RN
  LPN
  PT
  OT
  DC
  DPM
  DDS
  DMD
  PharmD
  PsyD
  PhD
  LCSW
  LMFT
  Other
}

enum PlanType {
  PPO
  HMO
  EPO
  POS
  HDHP
  Medicaid
  Medicare
  Other
}

enum InsuredType {
  Subscriber
  Dependent
}

// Models
model Organization {
  id                    String         @id @default(uuid())
  name                  String
  addresses             Json?          // Array of address objects
  phone                 String?
  email                 String?
  npi                   String?
  parentOrganizationId  String?
  parentOrganization    Organization?  @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id])
  childOrganizations    Organization[] @relation("OrganizationHierarchy")
  createdById           String?
  createdBy             User?          @relation("OrganizationCreatedBy", fields: [createdById], references: [id])
  updatedById           String?
  updatedBy             User?          @relation("OrganizationUpdatedBy", fields: [updatedById], references: [id])
  createdAt             BigInt         @default(0)
  updatedAt             BigInt         @default(0)

  users                 User[]         @relation("OrganizationUsers")
  patients              Patient[]
  providers             Provider[]
  visits                Visit[]
  claims                Claim[]
  rules                 Rule[]
  payors                Payor[]
  cptCodes              CPTCode[]
  providerCredentials   ProviderCredential[]

  @@map("organizations")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole
  organization  Organization @relation("OrganizationUsers", fields: [organizationId], references: [id])
  organizationId String
  createdAt     BigInt       @default(0)
  updatedAt     BigInt       @default(0)

  claimTimelines           ClaimTimeline[]
  attachments              Attachment[]
  createdOrganizations     Organization[] @relation("OrganizationCreatedBy")
  updatedOrganizations     Organization[] @relation("OrganizationUpdatedBy")
  createdPatients          Patient[]      @relation("PatientCreatedBy")
  updatedPatients          Patient[]      @relation("PatientUpdatedBy")
  createdProviders         Provider[]     @relation("ProviderCreatedBy")
  updatedProviders         Provider[]     @relation("ProviderUpdatedBy")
  createdPayors            Payor[]        @relation("PayorCreatedBy")
  updatedPayors            Payor[]        @relation("PayorUpdatedBy")
  createdClaims            Claim[]        @relation("ClaimCreatedBy")
  updatedClaims            Claim[]        @relation("ClaimUpdatedBy")
  createdRules             Rule[]         @relation("RuleCreatedBy")
  updatedRules             Rule[]         @relation("RuleUpdatedBy")
  createdVisits            Visit[]        @relation("VisitCreatedBy")
  updatedVisits            Visit[]        @relation("VisitUpdatedBy")
  createdCredentials       ProviderCredential[] @relation("CredentialCreatedBy")

  @@map("users")
}

model Patient {
  id                String              @id @default(uuid())
  firstName         String
  middleName        String?
  lastName          String
  suffix            String?
  prefix            String?
  dateOfBirth       BigInt
  gender            String?
  ssn               String?             // Encrypted
  phone             String?
  email             String?
  address           Json?
  organization      Organization        @relation(fields: [organizationId], references: [id])
  organizationId    String
  source            DataSource
  createdById       String
  createdBy         User                @relation("PatientCreatedBy", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?               @relation("PatientUpdatedBy", fields: [updatedById], references: [id])
  createdAt         BigInt              @default(0)
  updatedAt         BigInt              @default(0)

  visits            Visit[]
  claims            Claim[]
  insurancePolicies PatientInsurance[]
  attachments       Attachment[]
  eligibilityChecks EligibilityCheck[]

  @@map("patients")
}

model PatientInsurance {
  id                String       @id @default(uuid())
  patient           Patient      @relation(fields: [patientId], references: [id])
  patientId         String
  plan              PayorPlan    @relation(fields: [planId], references: [id])
  planId            String
  isPrimary         Boolean
  insuredType       InsuredType
  subscriberName    String?
  subscriberDob     BigInt?
  memberId          String
  insuranceCardPath String?      // Path to uploaded insurance card image
  createdAt         BigInt       @default(0)
  updatedAt         BigInt       @default(0)

  eligibilityChecks EligibilityCheck[]

  @@map("patient_insurances")
}

model Provider {
  id             String               @id @default(uuid())
  firstName      String
  middleName     String?
  lastName       String
  npi            String?
  specialty      String?
  licenseType    ProviderLicenseType
  organization   Organization         @relation(fields: [organizationId], references: [id])
  organizationId String
  source         DataSource
  createdById    String
  createdBy      User                 @relation("ProviderCreatedBy", fields: [createdById], references: [id])
  updatedById    String?
  updatedBy      User?                @relation("ProviderUpdatedBy", fields: [updatedById], references: [id])
  createdAt      BigInt               @default(0)
  updatedAt      BigInt               @default(0)

  visits              Visit[]
  claims              Claim[]
  providerCredentials ProviderCredential[]
  taxonomyCode        String?   // e.g. "207Q00000X" — required on 837P

  @@map("providers")
}

// Platform-managed canonical payor list seeded from Stedi's payer network.
// Clients never interact with this table directly — they search it and "enable"
// a MasterPayor for their org, which creates a Payor record linked here.
model MasterPayor {
  id                  String        @id @default(uuid())
  stediId             String        @unique          // Stedi's stable internal ID
  displayName         String                         // Canonical business name (e.g. "Aetna")
  primaryPayorId      String                         // Stedi primaryPayerId used for routing
  aliases             Json          @default("[]")   // Array of alternative IDs
  avatarUrl           String?
  coverageTypes       Json          @default("[]")   // e.g. ["medical", "dental", "vision"]
  transactionSupport  Json          @default("{}")   // eligibilityCheck, professionalClaimSubmission, claimPayment, claimStatus
  isActive            Boolean       @default(true)
  // Hierarchy: optional parent for subsidiaries (e.g. BCBS state plans under BCBS National)
  parentId            String?
  parent              MasterPayor?  @relation("MasterPayorHierarchy", fields: [parentId], references: [id])
  children            MasterPayor[] @relation("MasterPayorHierarchy")
  createdAt           BigInt        @default(0)
  updatedAt           BigInt        @default(0)
  payors              Payor[]
  providerCredentials ProviderCredential[]
  @@map("master_payors")
}

// Tracks which providers are credentialed with which payors.
// Used to surface warnings when a payor is disabled but providers are credentialed with it.
model ProviderCredential {
  id              String       @id @default(uuid())
  provider        Provider     @relation(fields: [providerId], references: [id])
  providerId      String
  masterPayor     MasterPayor  @relation(fields: [masterPayorId], references: [id])
  masterPayorId   String
  credentialType  String?      // e.g. "PAR" (participating), "NON-PAR", "Medicaid"
  effectiveDate   BigInt?      // Unix timestamp
  expirationDate  BigInt?      // Unix timestamp
  notes           String?
  organization    Organization @relation(fields: [organizationId], references: [id])
  organizationId  String
  createdById     String?
  createdBy       User?        @relation("CredentialCreatedBy", fields: [createdById], references: [id])
  createdAt       BigInt       @default(0)
  updatedAt       BigInt       @default(0)
  @@unique([providerId, masterPayorId, organizationId])
  @@map("provider_credentials")
}

model Payor {
  id                String         @id @default(uuid())
  name              String
  externalPayorId   String         @unique
  payorCategory     String
  billingTaxonomy   String
  address           Json?
  phone             String?
  portalUrl         String?
  masterPayor       MasterPayor?   @relation(fields: [masterPayorId], references: [id])
  masterPayorId     String?                     // FK to MasterPayor — set when org enables a master payor
  stediPayorId      String?                     // Stedi routing ID — separate from masterPayor.primaryPayorId for flexibility
  organization      Organization   @relation(fields: [organizationId], references: [id])
  organizationId    String
  createdById       String
  createdBy         User           @relation("PayorCreatedBy", fields: [createdById], references: [id])
  updatedById       String?
  updatedBy         User?          @relation("PayorUpdatedBy", fields: [updatedById], references: [id])
  createdAt         BigInt         @default(0)
  updatedAt         BigInt         @default(0)
  plans             PayorPlan[]
  claims            Claim[]
  @@map("payors")
}

model PayorPlan {
  id                String             @id @default(uuid())
  payor             Payor              @relation(fields: [payorId], references: [id])
  payorId           String
  planName          String
  planType          PlanType
  isInNetwork       Boolean
  createdAt         BigInt             @default(0)
  updatedAt         BigInt             @default(0)

  patientInsurances PatientInsurance[]

  @@map("payor_plans")
}

model Visit {
  id             String        @id @default(uuid())
  patient        Patient       @relation(fields: [patientId], references: [id])
  patientId      String
  provider       Provider      @relation(fields: [providerId], references: [id])
  providerId     String
  visitDate      BigInt
  visitTime      BigInt
  duration       Int
  visitType      VisitType
  location       VisitLocation
  status         VisitStatus
  visitSource    String?
  clinicalNotes  String?
  followUpPlan   String?
  notes          String?
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  source         DataSource    @default(Forager)
  createdById    String?
  createdBy      User?         @relation("VisitCreatedBy", fields: [createdById], references: [id])
  updatedById    String?
  updatedBy      User?         @relation("VisitUpdatedBy", fields: [updatedById], references: [id])
  createdAt      BigInt        @default(0)
  updatedAt      BigInt        @default(0)
  claims         Claim[]
  attachments    Attachment[]
  diagnoses      Diagnosis[]
  @@map("visits")
}

model Claim {
  id                   String        @id @default(uuid())
  claimNumber          String        @unique
  visit                Visit?        @relation(fields: [visitId], references: [id])
  visitId              String?
  patient              Patient       @relation(fields: [patientId], references: [id])
  patientId            String
  provider             Provider      @relation(fields: [providerId], references: [id])
  providerId           String
  payor                Payor         @relation(fields: [payorId], references: [id])
  payorId              String
  serviceDate          BigInt
  submissionDate       BigInt? 
  creationDate         BigInt        @default(0)
  billedAmount         Decimal       @db.Decimal(10, 2)
  allowedAmount        Decimal?      @db.Decimal(10, 2)
  paidAmount           Decimal?      @db.Decimal(10, 2)
  adjustmentAmount     Decimal?      @db.Decimal(10, 2)
  patientResponsibility Decimal?     @db.Decimal(10, 2)
  status               ClaimStatus
  denialCode           String?
  denialReason         String?
  notes                String?
  organization         Organization  @relation(fields: [organizationId], references: [id])
  organizationId       String
  source               DataSource    @default(Forager)
  createdById          String?
  createdBy            User?         @relation("ClaimCreatedBy", fields: [createdById], references: [id])
  updatedById          String?
  updatedBy            User?         @relation("ClaimUpdatedBy", fields: [updatedById], references: [id])
  createdAt            BigInt        @default(0)
  updatedAt            BigInt        @default(0)
  services             ClaimService[]
  timeline             ClaimTimeline[]
  attachments          Attachment[]
  diagnoses            Diagnosis[]
  paymentPostings      PaymentPosting[]
  // Stedi clearinghouse fields
  stediTransactionId   String?    // Stedi's transaction ID after 837 submission
  stediStatus          String?    // raw status from 277 ("accepted", "rejected", etc.)
  submittedToStediAt   DateTime?  // when we fired the 837 to Stedi

  @@map("claims")
}

model CPTCode {
  code           String         @id @unique
  description    String
  category       String?
  specialty      String?
  standardPrice  Decimal        @db.Decimal(10, 2)
  basePrice      Decimal?       @db.Decimal(10, 2)
  organization   Organization   @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      BigInt         @default(0)
  updatedAt      BigInt         @default(0)

  claimServices ClaimService[]
  // Provider-taxonomy-specific rate tiers (e.g. MD vs NP vs PT rates)
  rateTiers     CPTCodeRate[]

  @@map("cpt_codes")
}

// Per-taxonomy rate override for a CPT code.
// When a claim service is created, the system looks up the rendering provider's
// taxonomyCode and applies the matching tier rate instead of the base standardPrice.
model CPTCodeRate {
  id              String   @id @default(uuid())
  cptCode         CPTCode  @relation(fields: [cptCodeCode], references: [code], onDelete: Cascade)
  cptCodeCode     String
  // Taxonomy code (e.g. "207Q00000X" = Family Medicine MD)
  // Can also be a license type shorthand (e.g. "NP", "PT", "PA_C") for human-readable config
  taxonomyCode    String
  taxonomyLabel   String?  // Human-readable label e.g. "Nurse Practitioner"
  standardPrice   Decimal  @db.Decimal(10, 2)
  contractedPrice Decimal? @db.Decimal(10, 2)
  notes           String?
  organizationId  String
  createdAt       BigInt   @default(0)
  updatedAt       BigInt   @default(0)

  @@unique([cptCodeCode, taxonomyCode, organizationId])
  @@index([cptCodeCode])
  @@index([organizationId])
  @@map("cpt_code_rates")
}

model ClaimService {
  id             String    @id @default(uuid())
  claim          Claim     @relation(fields: [claimId], references: [id])
  claimId        String
  cptCode        CPTCode?  @relation(fields: [cptCodeCode], references: [code])
  cptCodeCode    String?
  description    String?
  quantity       Int
  unitPrice      Decimal   @db.Decimal(10, 2)
  totalPrice     Decimal   @db.Decimal(10, 2)
  contractedRate Decimal?  @db.Decimal(10, 2)
  modifiers      Json?
  createdAt      BigInt    @default(0)

  @@map("claim_services")
}

model ClaimTimeline {
  id        String   @id @default(uuid())
  claim     Claim    @relation(fields: [claimId], references: [id])
  claimId   String
  action    String
  status    String?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  notes     String?
  createdAt BigInt   @default(0)

  @@map("claim_timelines")
}

model Attachment {
  id          String    @id @default(uuid())
  claim       Claim?    @relation(fields: [claimId], references: [id])
  claimId     String?
  visit       Visit?    @relation(fields: [visitId], references: [id])
  visitId     String?
  patient     Patient?  @relation(fields: [patientId], references: [id])
  patientId   String?
  fileName    String
  fileType    String
  fileSize    Int
  filePath    String
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])
  uploadedById String
  createdAt   BigInt    @default(0)

  @@map("attachments")
}

model Rule {
  id             String       @id @default(uuid())
  name           String
  description    String?
  triggerType    String
  conditions     Json?
  actions        Json?
  isActive       Boolean      @default(true)
  flowData       Json?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdById    String?
  createdBy      User?        @relation("RuleCreatedBy", fields: [createdById], references: [id])
  updatedById    String?
  updatedBy      User?        @relation("RuleUpdatedBy", fields: [updatedById], references: [id])
  createdAt      BigInt       @default(0)
  updatedAt      BigInt       @default(0)

  ruleExecutions RuleExecution[]

  @@map("rules")
}

model RuleExecution {
  id          String   @id @default(uuid())
  rule        Rule     @relation(fields: [ruleId], references: [id])
  ruleId      String
  entityType  String
  entityId    String
  result      String
  executedAt  BigInt   @default(0)

  @@map("rule_executions")
}

// ─── Stedi Integration Models ─────────────────────────────────────────────────

model Diagnosis {
  id          String   @id @default(uuid())
  claimId     String?
  visitId     String?
  icdCode     String   // e.g. "J06.9", "M54.5"
  description String?
  isPrimary   Boolean  @default(false)
  sequence    Int      @default(1) // order matters on 837 — primary = 1
  createdAt   DateTime @default(now())

  claim Claim? @relation(fields: [claimId], references: [id], onDelete: Cascade)
  visit Visit? @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([visitId])
  @@map("diagnoses")
}

model EligibilityCheck {
  id                  String   @id @default(uuid())
  patientId           String
  patientInsuranceId  String   // FK to PatientInsurance (replaces insurancePolicyId)
  visitId             String?  // populated if check was triggered pre-visit
  organizationId      String   // multi-tenant: which org ran this check

  // Request context
  stediTransactionId  String?  // Stedi's transaction control number
  requestedAt         DateTime @default(now())

  // Response summary (parsed from 271)
  isEligible          Boolean?
  coverageActive      Boolean?
  planName            String?
  groupNumber         String?
  memberId            String?

  // Benefits (parsed from 271 EB segments)
  copayAmount         Decimal? @db.Decimal(10, 2)
  deductibleTotal     Decimal? @db.Decimal(10, 2)
  deductibleMet       Decimal? @db.Decimal(10, 2)
  deductibleRemaining Decimal? @db.Decimal(10, 2)
  oopTotal            Decimal? @db.Decimal(10, 2)
  oopMet              Decimal? @db.Decimal(10, 2)
  oopRemaining        Decimal? @db.Decimal(10, 2)

  // PT/rehab specific (therapy caps)
  therapyVisitsAllowed   Int?
  therapyVisitsUsed      Int?
  therapyVisitsRemaining Int?
  requiresAuthorization  Boolean?

  // Raw response stored for debugging/audit
  rawRequest   Json?
  rawResponse  Json?
  errorMessage String?  // populated if Stedi returned an error

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient         Patient         @relation(fields: [patientId], references: [id])
  patientInsurance PatientInsurance @relation(fields: [patientInsuranceId], references: [id])

  @@index([patientId])
  @@index([patientInsuranceId])
  @@index([visitId])
  @@index([organizationId])
  @@map("eligibility_checks")
}

model PaymentPosting {
  id              String   @id @default(uuid())
  claimId         String
  organizationId  String   // multi-tenant: which org this payment belongs to

  // ERA / 835 header info
  checkNumber  String?
  checkDate    DateTime?
  payerName    String?
  payeeNpi     String?

  // Payment amounts
  billedAmount          Decimal  @db.Decimal(10, 2)
  allowedAmount         Decimal? @db.Decimal(10, 2)
  paidAmount            Decimal  @db.Decimal(10, 2)
  patientResponsibility Decimal? @db.Decimal(10, 2)

  // CAS adjustment segments
  adjustments Json?  // [{ "groupCode": "CO", "reasonCode": "45", "amount": 50.00 }]

  // Denial / adjustment detail
  claimAdjustmentReason String?  // e.g. "CO-45", "PR-1", "CO-97"
  remarkCodes           String?  // comma-separated remark codes from 835

  // Raw 835 for this claim stored for audit
  rawEraSegment Json?

  postedAt    DateTime @default(now())
  postedById  String?  // userId who manually confirmed if applicable
  isAutoPosted Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([claimId])
  @@index([organizationId])
  @@map("payment_postings")
}

model StediWebhookLog {
  id            String    @id @default(uuid())
  eventType     String    // "transaction.processed", "claim.status.updated", etc.
  transactionId String?   // Stedi transaction ID
  claimId       String?   // resolved Forager claim ID
  organizationId String?  // resolved org ID for multi-tenant routing
  rawPayload    Json
  processedAt   DateTime?
  error         String?
  createdAt     DateTime  @default(now())

  @@index([transactionId])
  @@index([claimId])
  @@index([organizationId])
  @@map("stedi_webhook_logs")
}

