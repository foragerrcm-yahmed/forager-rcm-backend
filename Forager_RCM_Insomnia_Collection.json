      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/setup",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"admin@yourpractice.com\",\n  \"password\": \"YourPassword123!\",\n  \"firstName\": \"Your\",\n  \"lastName\": \"Name\",\n  \"organizationName\": \"Your Practice Name\"\n}"
      },
      "description": "One-time setup. Creates the first org and admin user. Disabled after first use."
